APP_NAME="Winter CMS"
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
FRONTEND_URL =
APP_LOCALE=en

GYM_API_KEY=

# Google Gemini API — used by GenerateBestGymsPages to rank gyms via AI + Google Search grounding
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
OPEN_AI_KEY=

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=database
DB_USERNAME=root
DB_PASSWORD=

# Second database for gymsdata list page (https://gymdues.com/gymsdata/) — PostgreSQL
# Omit or leave empty to use same as DB_* above
GYMSDATA_DB_HOST=
GYMSDATA_DB_PORT=5432
GYMSDATA_DB_DATABASE=
GYMSDATA_DB_USERNAME=
GYMSDATA_DB_PASSWORD=
GYMSDATA_DB_TABLE=gyms_data
# GYMSDATA_DB_SSLMODE=prefer
# GYMSDATA_DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Base URL for state card images (Browse Gyms By State). Images: {base}/{state-slug}.jpg (e.g. california.jpg)
# GYMSDATA_STATE_IMAGE_BASE_URL=https://gymdues.com/images/states
# State comparison endpoint: timeout (ms, default 12000), cache TTL (seconds, default 3600)
# GYMSDATA_STATE_COMPARISON_TIMEOUT_MS=12000
# GYMSDATA_STATE_COMPARISON_CACHE_TTL=3600

# Stripe for gymsdata purchase (buy all data)
# STRIPE_SECRET=sk_live_...
# STRIPE_WEBHOOK_SECRET_GYMSDATA=whsec_...  (from Stripe Dashboard → Webhooks → signing secret)

# Frontend origin for Stripe redirects (success → /gymsdata/checkout/success, cancel → /gymsdata/checkout/cancel)
# GYMSDATA_FRONTEND_URL=https://gymdues.com
# GYMSDATA_STRIPE_CURRENCY=usd
# Optional: require token for resend-purchase-email
# GYMSDATA_RESEND_TOKEN=your-secret-token

CACHE_DRIVER=file

SESSION_DRIVER=file

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

QUEUE_CONNECTION=sync

MAIL_MAILER=log
MAIL_LOG_CHANNEL=null
MAIL_HOST=null
MAIL_PORT=null
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=noreply@example.com
MAIL_FROM_NAME="${APP_NAME}"

ROUTES_CACHE=false
ASSET_CACHE=false
LINK_POLICY=detect
ENABLE_CSRF=true
DATABASE_TEMPLATES=false

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
